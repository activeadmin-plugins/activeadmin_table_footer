# frozen_string_literal: true

source "https://rubygems.org"

gemspec path: ".."

gem "activeadmin", "~> 3.5.0"
gem "rake"

group :test do
  gem "rspec-rails", "~> 7.0"
  gem "capybara"
  gem "capybara_active_admin", ">= 1.0.0"
  gem "sqlite3"
  gem "puma"
  gem "sassc-rails"
  gem "actionmailer"
  gem "simplecov", require: false
end
